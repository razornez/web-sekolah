}

model Sarpras {
  id         Int     @id @default(autoincrement())
  sekolahId  Int     @map("sekolah_id")
  kategoriId Int?    @map("kategori_id")
  nama       String
  jumlah     Int     @default(0)
  kondisi    String?
  keterangan String?

  sekolah  Sekolah          @relation(fields: [sekolahId], references: [id], onDelete: Cascade)
  kategori KategoriSarpras? @relation(fields: [kategoriId], references: [id])

  @@map("sarpras")
}

// =============================================================================
// PPDB
// =============================================================================

model JalurPpdb {
  id         Int     @id @default(autoincrement())
  sekolahId  Int     @map("sekolah_id")
  nama       String
  kuota      Int?
  keterangan String?

  sekolah     Sekolah           @relation(fields: [sekolahId], references: [id], onDelete: Cascade)
  pendaftaran PendaftaranPpdb[]

  @@map("jalur_ppdb")
}

model PendaftaranPpdb {
  id           Int          @id @default(autoincrement())
  sekolahId    Int          @map("sekolah_id")
  jalurId      Int?         @map("jalur_id")
  nisn         String?
  namaLengkap  String       @map("nama_lengkap")
  jenisKelamin JenisKelamin @map("jenis_kelamin")
  tempatLahir  String?      @map("tempat_lahir")
  tanggalLahir DateTime?    @map("tanggal_lahir") @db.Date
