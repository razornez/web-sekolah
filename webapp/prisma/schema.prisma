}

model PinjamanBuku {
  id             Int       @id @default(autoincrement())
  sekolahId      Int       @map("sekolah_id")
  bukuId         Int       @map("buku_id")
  siswaId        Int?      @map("siswa_id")
  durasiHari     Int?      @map("durasi_hari")
  tanggalPinjam  DateTime  @default(now()) @map("tanggal_pinjam")
  tanggalKembali DateTime? @map("tanggal_kembali")

  sekolah Sekolah          @relation(fields: [sekolahId], references: [id], onDelete: Cascade)
  buku    BukuPerpustakaan @relation(fields: [bukuId], references: [id])
  siswa   Siswa?           @relation(fields: [siswaId], references: [id], onDelete: SetNull)

  @@map("pinjaman_buku")
}

model PengunjungPerpustakaan {
  id        Int      @id @default(autoincrement())
  sekolahId Int      @map("sekolah_id")
  nama      String
  identitas String?
  tanggal   DateTime @default(now())

  sekolah Sekolah @relation(fields: [sekolahId], references: [id], onDelete: Cascade)

  @@map("pengunjung_perpustakaan")
}

// =============================================================================
// SARANA PRASARANA
// =============================================================================

model KategoriSarpras {
  id        Int    @id @default(autoincrement())
  sekolahId Int    @map("sekolah_id")
  nama      String

  sekolah Sekolah   @relation(fields: [sekolahId], references: [id], onDelete: Cascade)
  sarpras Sarpras[]

