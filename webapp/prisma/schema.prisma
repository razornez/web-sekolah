model Kelulusan {
  id         Int     @id @default(autoincrement())
  sekolahId  Int     @map("sekolah_id")
  siswaId    Int     @unique @map("siswa_id")
  status     String // LULUS / TIDAK LULUS
  keterangan String?

  sekolah Sekolah @relation(fields: [sekolahId], references: [id], onDelete: Cascade)
  siswa   Siswa   @relation(fields: [siswaId], references: [id], onDelete: Cascade)

  @@map("kelulusan")
}

model SettingKelulusan {
  id           Int       @id @default(autoincrement())
  sekolahId    Int       @map("sekolah_id")
  aktif        Boolean   @default(false)
  tanggalRilis DateTime? @map("tanggal_rilis")
  pengumuman   String?

  sekolah Sekolah @relation(fields: [sekolahId], references: [id], onDelete: Cascade)

  @@map("setting_kelulusan")
}

// =============================================================================
// E-VOTING OSIS
// =============================================================================

model CalonOsis {
  id        Int     @id @default(autoincrement())
  sekolahId Int     @map("sekolah_id")
  noUrut    Int     @map("no_urut")
  namaKetua String  @map("nama_ketua")
  namaWakil String? @map("nama_wakil")
  fotoKetua String? @map("foto_ketua")
  fotoWakil String? @map("foto_wakil")
  visi      String?
  misi      String?

  sekolah Sekolah         @relation(fields: [sekolahId], references: [id], onDelete: Cascade)
  vote    VotePemilihan[]

  @@map("calon_osis")
}

model VotePemilihan {
  id        Int      @id @default(autoincrement())
  sekolahId Int      @map("sekolah_id")
  calonId   Int      @map("calon_id")
  siswaId   Int      @map("siswa_id")
  votedAt   DateTime @default(now()) @map("voted_at")

  sekolah Sekolah   @relation(fields: [sekolahId], references: [id], onDelete: Cascade)
  calon   CalonOsis @relation(fields: [calonId], references: [id])
  siswa   Siswa     @relation(fields: [siswaId], references: [id])

  @@unique([sekolahId, siswaId]) // 1 siswa 1 suara per sekolah
  @@map("vote_pemilihan")
}

// =============================================================================
