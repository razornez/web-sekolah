// =============================================================================
// KEHADIRAN
// =============================================================================

model KehadiranSiswa {
  id         Int            @id @default(autoincrement())
  sekolahId  Int            @map("sekolah_id")
  siswaId    Int            @map("siswa_id")
  periodeId  Int?           @map("periode_id")
  tanggal    DateTime       @db.Date
  jamMasuk   DateTime?      @map("jam_masuk") @db.Time
  jamPulang  DateTime?      @map("jam_pulang") @db.Time
  jenis      JenisPresensi  @default(masuk)
  status     StatusPresensi @default(hadir)
  keterangan String?

  sekolah Sekolah  @relation(fields: [sekolahId], references: [id], onDelete: Cascade)
  siswa   Siswa    @relation(fields: [siswaId], references: [id], onDelete: Cascade)
  periode Periode? @relation(fields: [periodeId], references: [id])

  @@unique([siswaId, tanggal])
  @@index([sekolahId, tanggal])
  @@map("kehadiran_siswa")
}

model KehadiranGuru {
  id         Int            @id @default(autoincrement())
  sekolahId  Int            @map("sekolah_id")
  guruId     Int            @map("guru_id")
  tanggal    DateTime       @db.Date
  jamMasuk   DateTime?      @map("jam_masuk") @db.Time
  jamPulang  DateTime?      @map("jam_pulang") @db.Time
  status     StatusPresensi @default(hadir)
  keterangan String?

  sekolah Sekolah @relation(fields: [sekolahId], references: [id], onDelete: Cascade)
  guru    Guru    @relation(fields: [guruId], references: [id], onDelete: Cascade)

  @@index([sekolahId, tanggal])
  @@map("kehadiran_guru")
}

model SettingKehadiran {
  id         Int     @id @default(autoincrement())
  sekolahId  Int     @map("sekolah_id")
  jamMasuk   String  @map("jam_masuk")
  jamPulang  String  @map("jam_pulang")
  toleransi  Int     @default(0)
  keterangan String?

  sekolah Sekolah @relation(fields: [sekolahId], references: [id], onDelete: Cascade)

  @@map("setting_kehadiran")
}

// =============================================================================
// BK  (kasus/pelanggaran, kategori, mutasi, undangan ortu)
// =============================================================================

model KategoriKasus {
  id        Int    @id @default(autoincrement())
  sekolahId Int    @map("sekolah_id")
  nama      String
  poin      Int    @default(0)

  sekolah Sekolah      @relation(fields: [sekolahId], references: [id], onDelete: Cascade)
  kasus   KasusSiswa[]

  @@map("kategori_kasus")
}

model KasusSiswa {
  id         Int      @id @default(autoincrement())
  sekolahId  Int      @map("sekolah_id")
  siswaId    Int      @map("siswa_id")
  kategoriId Int?     @map("kategori_id")
  namaKasus  String   @map("nama_kasus")
  poin       Int      @default(0)
  tanggal    DateTime @db.Date
  keterangan String?

  sekolah  Sekolah        @relation(fields: [sekolahId], references: [id], onDelete: Cascade)
  siswa    Siswa          @relation(fields: [siswaId], references: [id], onDelete: Cascade)
  kategori KategoriKasus? @relation(fields: [kategoriId], references: [id])

  @@index([sekolahId])
  @@index([siswaId])
  @@map("kasus_siswa")
}

model MutasiSiswa {
  id         Int      @id @default(autoincrement())
  sekolahId  Int      @map("sekolah_id")
  siswaId    Int?     @map("siswa_id")
  jenis      String // masuk / keluar
  asalTujuan String?  @map("asal_tujuan")
  alasan     String?
  tanggal    DateTime @db.Date

  sekolah Sekolah @relation(fields: [sekolahId], references: [id], onDelete: Cascade)
  siswa   Siswa?  @relation(fields: [siswaId], references: [id], onDelete: SetNull)

  @@map("mutasi_siswa")
}

model UndanganOrtu {
  id         Int      @id @default(autoincrement())
  sekolahId  Int      @map("sekolah_id")
  siswaId    Int?     @map("siswa_id")
  perihal    String
  tanggal    DateTime @db.Date
  keterangan String?

  sekolah Sekolah @relation(fields: [sekolahId], references: [id], onDelete: Cascade)

  @@map("undangan_ortu")
}

// =============================================================================
// KEUANGAN / SPP  (normalisasi bayar1..12 -> baris tagihan + pembayaran)
// =============================================================================

model JenisPembayaran {
  id         Int     @id @default(autoincrement())
  sekolahId  Int     @map("sekolah_id")
  nama       String
  nominal    Int     @default(0)
  keterangan String?

  sekolah Sekolah      @relation(fields: [sekolahId], references: [id], onDelete: Cascade)
  tagihan TagihanSpp[]

  @@map("jenis_pembayaran")
}

model KodeRekening {
  id        Int    @id @default(autoincrement())
  sekolahId Int    @map("sekolah_id")
  kode      String
  nama      String

  sekolah Sekolah @relation(fields: [sekolahId], references: [id], onDelete: Cascade)

  @@unique([sekolahId, kode])
  @@map("kode_rekening")
}

model TagihanSpp {
  id        Int              @id @default(autoincrement())
  sekolahId Int              @map("sekolah_id")
  siswaId   Int              @map("siswa_id")
  jenisId   Int              @map("jenis_id")
  bulan     Int // 1..12 (gantikan bayar1..bayar12)
  tahun     Int
  nominal   Int              @default(0)
  status    StatusPembayaran @default(belum)

  sekolah    Sekolah         @relation(fields: [sekolahId], references: [id], onDelete: Cascade)
  siswa      Siswa           @relation(fields: [siswaId], references: [id], onDelete: Cascade)
  jenis      JenisPembayaran @relation(fields: [jenisId], references: [id])
  pembayaran PembayaranSpp[]

  @@unique([siswaId, jenisId, bulan, tahun])
  @@index([sekolahId])
  @@map("tagihan_spp")
}

model PembayaranSpp {
  id           Int      @id @default(autoincrement())
  tagihanId    Int      @map("tagihan_id")
  tanggalBayar DateTime @default(now()) @map("tanggal_bayar")
  jumlah       Int
  kodeRekening String?  @map("kode_rekening")
  petugas      String?

  tagihan  TagihanSpp @relation(fields: [tagihanId], references: [id], onDelete: Cascade)
  kwitansi Kwitansi?

  @@map("pembayaran_spp")
}

model Kwitansi {
  id           Int      @id @default(autoincrement())
  pembayaranId Int      @unique @map("pembayaran_id")
  nomor        String
  tanggal      DateTime @default(now())

  pembayaran PembayaranSpp @relation(fields: [pembayaranId], references: [id], onDelete: Cascade)

  @@map("kwitansi")
}

// =============================================================================
// PERPUSTAKAAN
