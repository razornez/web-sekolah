# PostgreSQL lokal (dev) — di-setup via scoop (PostgreSQL 18.4)
# Salin file ini menjadi .env saat scaffold proyek Next.js.
# Untuk lokal, DATABASE_URL dan DIRECT_URL sama. Saat pindah ke Supabase,
# DATABASE_URL = connection pooler (port 6543), DIRECT_URL = direct (port 5432).

DATABASE_URL="postgresql://websekolah:websekolah_dev@localhost:5432/websekolah_dev?schema=public"
DIRECT_URL="postgresql://websekolah:websekolah_dev@localhost:5432/websekolah_dev?schema=public"

# Auth.js (NextAuth v5) — generate: `npx auth secret`
AUTH_SECRET="ganti-dengan-secret-acak"
AUTH_TRUST_HOST="true"

# AUTH_URL: WAJIB sesuai origin aplikasi.
#  - Dev   : http://localhost:3002  (cookie sesi non-secure, normal utk HTTP lokal)
#  - PROD  : https://domain-anda.com (HARUS https → cookie sesi otomatis Secure +
#            prefix __Secure-; tanpa https sesi gagal/tidak aman)
AUTH_URL="http://localhost:3002"

# NODE_ENV=production saat deploy → mengaktifkan HSTS header & build produksi.
# Jalankan: npm run build && npm start  (BUKAN next dev) di produksi.

# CRON_SECRET: rahasia untuk endpoint /api/cron/* (mis. cleanup demo 24 jam).
# Generate acak (mis. `openssl rand -hex 16`). Scheduler eksternal kirim header
# x-cron-secret: <nilai> setiap jam ke /api/cron/cleanup-demo.
CRON_SECRET="ganti-dengan-rahasia-cron-acak"

# EMAIL_ENCRYPTION_KEY: kunci 32 bytes (64 hex char) untuk enkripsi AES-256-GCM
# kredensial email (SMTP password, Resend API key) di database.
# Generate: openssl rand -hex 32
EMAIL_ENCRYPTION_KEY="ganti-dengan-64-karakter-hex-acak"
